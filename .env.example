# ==============================================================
# ComplianceFlow AI — Platform Environment Variables
# ==============================================================
# Copy this file to .env and fill in your values.
# These are PLATFORM-LEVEL secrets only.
# Client credentials are NEVER stored here — they use STS AssumeRole.
# ==============================================================

# --- Google Gemini (LLM Reasoning Engine) ---
GEMINI_API_KEY=your-gemini-api-key-here

# --- Platform AWS Identity ---
# This is YOUR platform's AWS IAM user, used for:
#   1. STS AssumeRole (to access client accounts)
#   2. SES (to send compliance reports)
# Permissions needed: sts:AssumeRole, ses:SendEmail, ses:SendRawEmail
PLATFORM_AWS_ACCESS_KEY_ID=
PLATFORM_AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# --- Email Reporting (AWS SES) ---
# Must be a verified SES identity (domain or email address)
AWS_SES_FROM_EMAIL=reports@complianceflow.ai

# --- Runtime ---
NODE_ENV=development
